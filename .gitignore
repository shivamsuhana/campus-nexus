# ============================================
# SENSITIVE FILES - NEVER COMMIT TO GITHUB
# ============================================

# Database Configuration (Contains credentials!)
config/database.php
config/database.local.php
config/.env.local

# Environment Variables
.env
.env.local
.env.*.local

# User Uploads (Large binary files)
uploads/*
!uploads/.gitkeep
!uploads/*/.gitkeep

