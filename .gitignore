# ============================================
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.sublime-project
.sublime-workspace

# ============================================
# LOG FILES & TEMP
# ============================================
*.log
debug.log
error.log
logs/
temp/
tmp/

# ============================================
# SYSTEM FILES
# ============================================
.DS_Store
.env.backup
*.bak
*.tmp

